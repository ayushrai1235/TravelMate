{
  "name": "travelmate-ai",
  "version": "1.0.0",
  "private": true,
  "description": "TravelMate AI - Intelligent multi-modal trip planner",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "cd apps/api && .\\.venv\\Scripts\\uvicorn app.main:app --reload --port 8000",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "railkit": "^4.0.1"
  }
}
