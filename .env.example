# Template for TravelMate AI Environment Variables
# Copy this file to `.env` or appropriate local env files

# === Database ===
# Used by FastAPI / Alembic
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db.your-project.supabase.co:5432/postgres
REDIS_URL=redis://localhost:6379/0
MOCK_EXTERNAL_APIS=False

# === Supabase Setup ===
NEXT_PUBLIC_SUPABASE_URL=https://oukykrvompzmeuwfufwa.supabase.co
# Preferred for new Supabase projects. Legacy anon key still works with app fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

SUPABASE_URL=https://oukykrvompzmeuwfufwa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === External APIs (Placeholder) ===
GOOGLE_MAPS_API_KEY=your_google_maps_key
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
RAILRADAR_API_KEY=your_railradar_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL_NAME=gemini-3.5-flash

